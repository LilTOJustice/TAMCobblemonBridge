{
  "schemaVersion": 1,
  "id": "tamcobblemonbridge",
  "version": "${version}",

  "name": "TAMCobblemonBridge",
  "description": "Cobblemon bridge for TrueAdaptiveMusic",
  "authors": ["LilTOJustice"],
  "contact": {},

  "license": "GPL-3.0",

  "environment": "client",
  "entrypoints": {
    "client": ["liltojustice.tamcobblemonbridge.client.TamCobblemonBridgeClient"],
  },

  "mixins": [
    {
      "config": "tamcobblemonbridge.client.mixins.json",
